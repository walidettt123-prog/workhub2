<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - WorkHub</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
    <div class="app-container">
        <!-- Top Nav -->
        <nav class="top-nav">
            <div class="nav-left">
                <div class="logo">
                    <i class="fas fa-bolt"></i>
                    <span>WorkHub <small style="font-size:12px; opacity:0.7;">Admin</small></span>
                </div>
            </div>
            <div class="nav-right">
                <span style="margin-right: 15px; color: #94a3b8;">Hola, <%= user.username %></span>
                <a href="/dashboard" class="btn-secondary">Ver Dashboard</a>
                <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i></a>
            </div>
        </nav>

        <div class="admin-content">
            <div class="admin-header">
                <h1><i class="fas fa-cog"></i> Panel de Administración</h1>
                <p>Gestiona enlaces, categorías y usuarios de tu equipo.</p>
            </div>

            <!-- Success/Error Messages -->
            <% if (typeof success !== 'undefined' && success) { %>
                <div class="alert success"><i class="fas fa-check-circle"></i> <%= success %></div>
            <% } %>
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
            <% } %>

            <!-- Quick Stats -->
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-link"></i></div>
                    <div class="stat-info">
                        <div class="stat-number"><%= links.length %></div>
                        <div class="stat-label">Enlaces totales</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-folder"></i></div>
                    <div class="stat-info">
                        <div class="stat-number"><%= categories.length %></div>
                        <div class="stat-label">Categorías</div>
                    </div>
                </div>
            </div>

            <!-- Add New Link Form -->
            <div class="admin-section">
                <h2><i class="fas fa-plus-circle"></i> Añadir nuevo enlace</h2>
                <form action="/admin/add-link" method="POST" class="admin-form">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Título del enlace</label>
                            <input type="text" name="title" placeholder="Gmail, CRM, Drive..." required>
                        </div>
                        <div class="form-group">
                            <label>URL</label>
                            <input type="url" name="url" placeholder="https://..." required>
                        </div>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label>Categoría</label>
                            <select name="category_id" required>
                                <% categories.forEach(cat => { %>
                                    <option value="<%= cat.id %>"><%= cat.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Icono (URL o nombre FontAwesome)</label>
                            <input type="text" name="icon" placeholder="fas fa-envelope o /icons/gmail.svg">
                        </div>
                    </div>

                    <button type="submit" class="btn-primary">
                        <i class="fas fa-plus"></i> Añadir Enlace
                    </button>
                </form>
            </div>

            <!-- Add Category -->
            <div class="admin-section">
                <h2><i class="fas fa-folder-plus"></i> Añadir nueva categoría</h2>
                <form action="/admin/add-category" method="POST" class="admin-form-inline">
                    <input type="text" name="name" placeholder="Nombre de la categoría" required>
                    <button type="submit" class="btn-primary">Añadir Categoría</button>
                </form>
            </div>

            <!-- Links Table -->
            <div class="admin-section">
                <h2><i class="fas fa-list"></i> Gestionar enlaces (<%= links.length %>)</h2>
                
                <div class="table-container">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Título</th>
                                <th>URL</th>
                                <th>Categoría</th>
                                <th>Favorito</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% links.forEach(link => { %>
                            <tr>
                                <td><strong><%= link.title %></strong></td>
                                <td><a href="<%= link.url %>" target="_blank" style="color:#60a5fa;"><%= link.url.length > 40 ? link.url.substring(0,40) + '...' : link.url %></a></td>
                                <td><span class="badge"><%= link.category_name || 'Sin categoría' %></span></td>
                                <td>
                                    <form action="/admin/toggle-favorite" method="POST" style="display:inline;">
                                        <input type="hidden" name="id" value="<%= link.id %>">
                                        <button type="submit" class="icon-btn <%= link.is_favorite ? 'active' : '' %>">
                                            <i class="fas fa-star"></i>
                                        </button>
                                    </form>
                                </td>
                                <td class="actions">
                                    <!-- Edit form (simplified) -->
                                    <form action="/admin/edit-link" method="POST" style="display:inline;">
                                        <input type="hidden" name="id" value="<%= link.id %>">
                                        <input type="text" name="title" value="<%= link.title %>" style="width:120px; padding:4px;" required>
                                        <input type="url" name="url" value="<%= link.url %>" style="width:180px; padding:4px;" required>
                                        <button type="submit" class="btn-small">Guardar</button>
                                    </form>
                                    
                                    <form action="/admin/delete-link" method="POST" style="display:inline;" onsubmit="return confirm('¿Eliminar este enlace?')">
                                        <input type="hidden" name="id" value="<%= link.id %>">
                                        <button type="submit" class="btn-danger btn-small">Eliminar</button>
                                    </form>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <style>
        .admin-content { padding: 30px; max-width: 1400px; margin: 0 auto; }
        .admin-header { margin-bottom: 30px; }
        .admin-header h1 { color: white; margin-bottom: 8px; }
        .admin-section { 
            background: #1e293b; 
            padding: 25px; 
            border-radius: 12px; 
            margin-bottom: 25px;
            border: 1px solid #334155;
        }
        .admin-form .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .form-group { margin-bottom: 15px; }
        .form-group label { display: block; color: #94a3b8; margin-bottom: 6px; font-size: 14px; }
        .form-group input, .form-group select { 
            width: 100%; padding: 10px 14px; 
            background: #0f172a; border: 1px solid #334155; 
            border-radius: 8px; color: white; 
        }
        .admin-form-inline { display: flex; gap: 12px; }
        .admin-form-inline input { flex: 1; padding: 10px 14px; background: #0f172a; border: 1px solid #334155; border-radius: 8px; color: white; }
        
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 20px; margin-bottom: 30px; }
        .stat-card { background: #1e293b; padding: 20px; border-radius: 12px; display: flex; align-items: center; gap: 15px; border: 1px solid #334155; }
        .stat-icon { font-size: 28px; color: #3b82f6; }
        .stat-number { font-size: 28px; font-weight: 700; color: white; }
        .stat-label { color: #94a3b8; font-size: 14px; }
        
        .admin-table { width: 100%; border-collapse: collapse; }
        .admin-table th, .admin-table td { padding: 14px 16px; text-align: left; border-bottom: 1px solid #334155; }
        .admin-table th { background: #0f172a; color: #94a3b8; font-weight: 600; }
        .admin-table tr:hover { background: #0f172a; }
        
        .actions { display: flex; gap: 8px; flex-wrap: wrap; }
        .btn-small { padding: 6px 12px; font-size: 13px; }
        .btn-danger { background: #ef4444; color: white; border: none; border-radius: 6px; cursor: pointer; }
        .icon-btn { background: none; border: none; color: #64748b; cursor: pointer; font-size: 18px; }
        .icon-btn.active { color: #fbbf24; }
        
        .alert { padding: 12px 20px; border-radius: 8px; margin-bottom: 20px; }
        .alert.success { background: #166534; color: #86efac; }
        .alert.error { background: #991b1b; color: #fca5a5; }
    </style>
</body>
</html>